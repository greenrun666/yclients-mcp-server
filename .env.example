# YCLIENTS API Tokens
# Get partner token from: https://yclients.com/appstore/developers
YCLIENTS_PARTNER_TOKEN=your_partner_token_here

# User token (optional, for user-specific operations)
# Obtain via API auth endpoint
YCLIENTS_USER_TOKEN=

# YCLIENTS API Base URL (default)
YCLIENTS_BASE_URL=https://api.yclients.com/api/v1

# MCP Server Configuration
# Transport: "stdio" for local, "http" for remote (Timeweb)
MCP_TRANSPORT=http

# HTTP Server Settings
MCP_HOST=0.0.0.0
MCP_PORT=8000

# Logging level: DEBUG, INFO, WARNING, ERROR
MCP_LOG_LEVEL=INFO
